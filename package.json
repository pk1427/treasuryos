{
  "name": "treasuryos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "description": "DeFi treasury risk intelligence with onchain risk attestations",
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
